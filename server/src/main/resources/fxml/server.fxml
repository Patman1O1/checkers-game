<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.uic.cs342.ServerController"
            styleClass="server-root"
            prefWidth="820.0" prefHeight="560.0">

    <!-- ── Top Status Bar ───────────────────────────────────────────────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="status-bar" spacing="20.0" alignment="CENTER_LEFT">
            <padding><Insets top="10.0" right="16.0" bottom="10.0" left="16.0"/></padding>

            <Label text="♟ Checkers Server" styleClass="server-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="statusLabel" text="● Starting…" styleClass="status-badge"/>
            <Label fx:id="portLabel" text="Port: 8080" styleClass="info-badge"/>
            <Label fx:id="onlineLabel" text="Online: 0" styleClass="info-badge"/>
            <Label fx:id="gamesLabel" text="Games: 0" styleClass="info-badge"/>
        </HBox>
    </top>

    <!-- ── Log List ─────────────────────────────────────────────────────────────────────────────────────────────── -->
    <center>
        <VBox>
            <padding><Insets right="12.0" left="12.0"/></padding>

            <Label text="Activity Log" styleClass="section-label">
                <VBox.margin><Insets top="10.0" bottom="4.0"/></VBox.margin>
            </Label>

            <ListView fx:id="logList" styleClass="log-list" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>

    <!-- ── Bottom Toolbar ───────────────────────────────────────────────────────────────────────────────────────── -->
    <bottom>
        <HBox styleClass="toolbar" spacing="10.0" alignment="CENTER_RIGHT">
            <padding><Insets top="8.0" right="12.0" bottom="8.0" left="12.0"/></padding>
            <Button text="Refresh Stats" onAction="#refreshStats" styleClass="tool-button"/>
            <Button text="Clear Log" onAction="#clearLog" styleClass="tool-button danger"/>
        </HBox>
    </bottom>
</BorderPane>