<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.uic.cs342.project3.frontend.ServerController"
      styleClass="root">

    <!-- Status indicator -->
    <HBox styleClass="title-bar" alignment="CENTER_LEFT" spacing="8">
        <Region fx:id="statusDot" styleClass="status-dot-online" prefWidth="8" prefHeight="8"/>
        <Label fx:id="statusLabel" text="SERVER RUNNING" styleClass="status-label"/>
        <Button fx:id="statusButton" text="STOP" styleClass="status-button-stop" onAction="#toggleServer"/>
    </HBox>

    <!-- Stats bar (unchanged) -->
    <HBox styleClass="stats-bar" spacing="24" alignment="CENTER_LEFT">
        <Label text="GAMES ACTIVE:" styleClass="stat-key"/>
        <Label fx:id="activeGamesLabel" text="0" styleClass="stat-value-green"/>
        <Region HBox.hgrow="ALWAYS" prefWidth="1" styleClass="stat-divider"/>
        <Label text="USERS ONLINE:" styleClass="stat-key"/>
        <Label fx:id="onlineUsersLabel" text="0" styleClass="stat-value-yellow"/>
        <Region HBox.hgrow="ALWAYS" prefWidth="1" styleClass="stat-divider"/>
        <Label text="UPTIME:" styleClass="stat-key"/>
        <Label fx:id="uptimeLabel" text="00:00:00" styleClass="stat-value"/>
        <Region HBox.hgrow="ALWAYS" prefWidth="1" styleClass="stat-divider"/>
        <Label fx:id="clockLabel" text="00:00:00" styleClass="stat-value"/>
    </HBox>

    <!-- Log list — fills all remaining height and full width -->
    <ListView fx:id="logList"
              styleClass="log-list"
              VBox.vgrow="NEVER"/>

</VBox>