<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.uic.cs342.project3.controllers.LobbyController"
            styleClass="lobby-root"
            prefWidth="1100.0" prefHeight="700.0">

    <!-- ── Header ───────────────────────────────────────────────────────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="lobby-header" alignment="CENTER_LEFT" spacing="16.0">
            <padding><Insets top="14.0" right="20.0" bottom="14.0" left="20.0"/></padding>
            <Label text="♟" styleClass="header-crown"/>
            <VBox spacing="2.0">
                <Label text="Game Lobby" styleClass="lobby-title"/>
                <Label fx:id="welcomeLabel" text="Welcome!" styleClass="lobby-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" styleClass="status-msg" visible="false" managed="false"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="danger-button"/>
        </HBox>
    </top>

    <!-- ── Main Content ─────────────────────────────────────────────────────────────────────────────────────────── -->
    <center>
        <HBox spacing="16.0">
            <padding><Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/></padding>

            <!-- ── Left Column: Stats + New Game ────────────────────────────────────────────────────────────────── -->
            <VBox spacing="14.0" prefWidth="260.0" minWidth="220.0">

                <!-- ── Stats Card ───────────────────────────────────────────────────────────────────────────────── -->
                <VBox styleClass="card" spacing="10.0">
                    <Label text="Your Statistics" styleClass="card-title"/>
                    <Separator/>
                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="Wins" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="winsLabel" text="0" styleClass="stat-wins"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="Losses" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lossesLabel" text="0" styleClass="stat-losses"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="Draws" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="drawsLabel" text="0" styleClass="stat-draws"/>
                    </HBox>
                    <Separator/>
                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="Win Rate" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="winRateLabel" text="0.0%" styleClass="stat-rate"/>
                    </HBox>
                </VBox>

                <!-- ── New Game Card ────────────────────────────────────────────────────────────────────────────── -->
                <VBox styleClass="card" spacing="10.0" VBox.vgrow="ALWAYS">
                    <Label text="Start New Game" styleClass="card-title"/>
                    <Separator/>
                    <Button text="Play vs AI"
                            onAction="#handlePlayVsAI"
                            styleClass="ai-button"
                            maxWidth="Infinity"/>
                    <Button fx:id="challengeButton"
                            text="Challenge Selected Player"
                            onAction="#handleChallengeSelected"
                            styleClass="challenge-button"
                            maxWidth="Infinity"
                            disable="true"/>
                    <Button fx:id="challengeFriendButton"
                            text="Challenge Selected Friend"
                            onAction="#handleChallengeFriend"
                            styleClass="challenge-button"
                            maxWidth="Infinity"/>
                </VBox>

                <!-- ── Incoming challenge panel ─────────────────────────────────────────────────────────────────── -->
                <VBox styleClass="card" spacing="8.0">
                    <Label fx:id="challengeLabel"
                           styleClass="challenge-notify"
                           visible="false" managed="false"
                           wrapText="true"/>
                    <Button fx:id="acceptChallengeButton"
                            text="✅  Accept Challenge"
                            onAction="#handleAcceptChallenge"
                            styleClass="ai-button"
                            maxWidth="Infinity"
                            visible="false" managed="false"/>
                    <Button fx:id="declineChallengeButton"
                            text="❌  Decline Challenge"
                            onAction="#handleDeclineChallenge"
                            styleClass="danger-button"
                            maxWidth="Infinity"
                            visible="false" managed="false"/>
                </VBox>
            </VBox>

            <!-- ── Middle Column: Online Players ────────────────────────────────────────────────────────────────── -->
            <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10.0">
                    <Label text="🟢  Online Players" styleClass="card-title"/>
                    <Label text="Select a player, then click Challenge" styleClass="card-subtitle"/>
                    <Separator/>
                    <ListView fx:id="onlineUsersList" styleClass="player-list" VBox.vgrow="ALWAYS"/>
                </VBox>
            </VBox>

            <!-- ── Right Column: Friends ────────────────────────────────────────────────────────────────────────── -->
            <VBox spacing="14.0" prefWidth="300.0" minWidth="260.0">

                <!-- ── Send Friend Request UI ───────────────────────────────────────────────────────────────────── -->
                <VBox styleClass="card" spacing="10.0">
                    <Label text="Send Friend Request" styleClass="card-title"/>
                    <HBox spacing="8.0">
                        <TextField fx:id="friendRequestField"
                                   promptText="Enter username"
                                   styleClass="auth-field"
                                   HBox.hgrow="ALWAYS"
                                   onAction="#handleSendFriendRequest"/>
                        <Button text="Send" onAction="#handleSendFriendRequest" styleClass="secondary-button"/>
                    </HBox>
                </VBox>

                <!-- ── Friend Requests UI ───────────────────────────────────────────────────────────────────────── -->
                <VBox styleClass="card" spacing="8.0">
                    <Label text="Friend Requests" styleClass="card-title"/>
                    <Label text="Select a request, then Accept or Decline" styleClass="card-subtitle"/>
                    <Separator/>
                    <ListView fx:id="incomingRequestsList" styleClass="player-list" prefHeight="100.0"/>
                    <HBox spacing="8.0">
                        <Button text="✅ Accept"
                                onAction="#handleAcceptFriendRequest"
                                styleClass="ai-button"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="❌ Decline"
                                onAction="#handleDeclineFriendRequest"
                                styleClass="danger-button"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                </VBox>

                <!-- ── Friend List ──────────────────────────────────────────────────────────────────────────────── -->
                <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10.0">
                    <Label text="Friends" styleClass="card-title"/>
                    <Label text="● = Online  ○ = Offline" styleClass="card-subtitle"/>
                    <Separator/>
                    <ListView fx:id="friendsList" styleClass="player-list" VBox.vgrow="ALWAYS"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>