<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.uic.cs342.project3.frontend.LobbyController"
      styleClass="screen-root">

    <Region styleClass="bg-gradient" VBox.vgrow="ALWAYS"
            minWidth="1" minHeight="1" maxWidth="1" maxHeight="1"
            translateX="-9999"/>

    <!-- ── Header bar ── -->
    <HBox styleClass="lobby-header" alignment="CENTER_LEFT" spacing="16">
        <StackPane styleClass="crown-circle-sm">
            <Label text="♛" styleClass="crown-icon-sm"/>
        </StackPane>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Game Lobby" styleClass="lobby-title"/>
            <Label fx:id="welcomeLabel" text="Welcome!" styleClass="lobby-subtitle"/>
        </VBox>
        <Button text="Logout" styleClass="danger-button" onAction="#handleLogout"/>
    </HBox>

    <!-- ── 3-column body ── -->
    <HBox VBox.vgrow="ALWAYS" spacing="16" styleClass="lobby-body">

        <!-- LEFT COLUMN: Stats + New Game -->
        <VBox spacing="16" prefWidth="260" minWidth="220">

            <!-- Player Stats card -->
            <VBox styleClass="card" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🏆" styleClass="card-icon"/>
                    <Label text="Your Statistics" styleClass="card-title"/>
                </HBox>

                <HBox alignment="CENTER_LEFT">
                    <Label text="Wins" styleClass="stat-key" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="winsLabel" text="0" styleClass="badge-green"/>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Losses" styleClass="stat-key" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lossesLabel" text="0" styleClass="badge-red"/>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Draws" styleClass="stat-key" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="drawsLabel" text="0" styleClass="badge-gray"/>
                </HBox>
                <Separator styleClass="card-separator"/>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Win Rate" styleClass="stat-key-bold" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="winRateLabel" text="0.0%" styleClass="badge-blue"/>
                </HBox>
            </VBox>

            <!-- New Game card -->
            <VBox styleClass="card" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🎮" styleClass="card-icon"/>
                    <Label text="Start New Game" styleClass="card-title"/>
                </HBox>
                <Label text="Choose your opponent" styleClass="card-subtitle"/>

                <Button text="🤖  Play vs AI"
                        styleClass="ai-button"
                        maxWidth="Infinity"
                        onAction="#handlePlayVsAI"/>

                <Button fx:id="challengeButton"
                        text="Challenge Selected Player"
                        styleClass="challenge-button"
                        maxWidth="Infinity"
                        visible="false"
                        managed="false"
                        onAction="#handleChallenge"/>

                <!-- Selected opponent indicator -->
                <HBox fx:id="selectedRow" alignment="CENTER_LEFT" spacing="8"
                      visible="false" managed="false">
                    <Region styleClass="dot-online" prefWidth="8" prefHeight="8"/>
                    <Label fx:id="selectedOpponentLabel" text="" styleClass="selected-name"/>
                    <Button text="✕" styleClass="deselect-button" onAction="#handleDeselect"/>
                </HBox>
            </VBox>

        </VBox>

        <!-- MIDDLE COLUMN: Online Players -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="🟢" styleClass="card-icon"/>
                <Label fx:id="onlineCountLabel" text="Online Players (0)" styleClass="card-title"
                       HBox.hgrow="ALWAYS"/>
            </HBox>
            <Label text="Click a player to select them" styleClass="card-subtitle"/>

            <ScrollPane styleClass="list-scroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                        hbarPolicy="NEVER">
                <ListView fx:id="onlinePlayersList" styleClass="players-list"/>
            </ScrollPane>
        </VBox>

        <!-- RIGHT COLUMN: Friends -->
        <VBox spacing="16" prefWidth="280" minWidth="240">

            <!-- Add Friend card -->
            <VBox styleClass="card" spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="➕" styleClass="card-icon"/>
                    <Label text="Add Friend" styleClass="card-title"/>
                </HBox>
                <HBox spacing="8">
                    <TextField fx:id="friendInput"
                               promptText="Enter username"
                               styleClass="auth-field"
                               HBox.hgrow="ALWAYS"
                               onAction="#handleAddFriend"/>
                    <Button text="Add" styleClass="primary-button" onAction="#handleAddFriend"/>
                </HBox>
                <Label fx:id="friendError" styleClass="error-label" visible="false" managed="false"/>
            </VBox>

            <!-- Friends list card -->
            <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="👥" styleClass="card-icon"/>
                    <Label fx:id="friendsCountLabel" text="Friends (0)" styleClass="card-title"/>
                </HBox>

                <ScrollPane styleClass="list-scroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                            hbarPolicy="NEVER">
                    <ListView fx:id="friendsList" styleClass="friends-list"/>
                </ScrollPane>
            </VBox>
        </VBox>
    </HBox>
</VBox>
