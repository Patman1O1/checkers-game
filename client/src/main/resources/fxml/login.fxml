<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.uic.cs342.project3.controllers.LoginController"
      styleClass="login-root"
      alignment="CENTER"
      prefWidth="480.0" prefHeight="560.0">

    <padding><Insets top="40.0" right="50.0" bottom="40.0" left="50.0"/></padding>

    <!-- ── Logo / Title ─────────────────────────────────────────────────────────────────────────────────────────── -->
    <VBox alignment="CENTER" spacing="6.0">
        <VBox.margin><Insets bottom="24.0"/></VBox.margin>
        <Label text="♟" styleClass="crown-icon"/>
        <Label text="Checkers Online" styleClass="app-title"/>
        <Label text="Multiplayer Checkers with AI" styleClass="app-subtitle"/>
    </VBox>

    <!-- ── Tab Pane ─────────────────────────────────────────────────────────────────────────────────────────────── -->
    <TabPane fx:id="tabPane" styleClass="auth-tabs" tabClosingPolicy="UNAVAILABLE">

        <!-- ── Login Tab ────────────────────────────────────────────────────────────────────────────────────────── -->
        <Tab text="Login">
            <VBox spacing="14.0" styleClass="tab-content">
                <padding><Insets top="24.0" bottom="24.0"/></padding>

                <Label text="Welcome Back" styleClass="card-title"/>
                <Label text="Enter your credentials to play" styleClass="card-subtitle"/>

                <Label text="Username" styleClass="field-label"/>
                <TextField fx:id="loginUsernameField"
                           promptText="Enter your username"
                           styleClass="auth-field"
                           onAction="#handleLogin"/>

                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="loginPasswordField"
                               promptText="Enter your password"
                               styleClass="auth-field"
                               onAction="#handleLogin"/>

                <Label fx:id="loginErrorLabel"
                       styleClass="error-label"
                       wrapText="true"
                       visible="false" managed="false"/>

                <Button fx:id="loginButton"
                        text="Login"
                        defaultButton="true"
                        onAction="#handleLogin"
                        styleClass="primary-button"
                        maxWidth="Infinity"/>
            </VBox>
        </Tab>

        <!-- ── Sign Up Tab ──────────────────────────────────────────────────────────────────────────────────────── -->
        <Tab text="Sign Up">
            <VBox spacing="12.0" styleClass="tab-content">
                <padding><Insets top="20.0" bottom="20.0"/></padding>

                <Label text="Create Account" styleClass="card-title"/>
                <Label text="Sign up to start playing" styleClass="card-subtitle"/>

                <Label text="Username (3–20 characters)" styleClass="field-label"/>
                <TextField fx:id="signupUsernameField"
                           promptText="Choose a unique username"
                           styleClass="auth-field"
                           onAction="#handleSignup"/>

                <Label text="Password (min 6 characters)" styleClass="field-label"/>
                <PasswordField fx:id="signupPasswordField"
                               promptText="Create a password"
                               styleClass="auth-field"
                               onAction="#handleSignup"/>

                <Label text="Confirm Password" styleClass="field-label"/>
                <PasswordField fx:id="signupConfirmField"
                               promptText="Re-enter your password"
                               styleClass="auth-field"
                               onAction="#handleSignup"/>

                <Label fx:id="signupErrorLabel"
                       styleClass="error-label"
                       wrapText="true"
                       visible="false" managed="false"/>

                <Label fx:id="signupSuccessLabel"
                       styleClass="success-label"
                       wrapText="true"
                       visible="false" managed="false"/>

                <Button fx:id="signupButton"
                        text="Sign Up"
                        onAction="#handleSignup"
                        styleClass="primary-button"
                        maxWidth="Infinity"/>
            </VBox>
        </Tab>
    </TabPane>
</VBox>