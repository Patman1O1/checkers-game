<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
    Game.fxml — converted from Game.tsx
    Layout: header / (board  |  players + chat)
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.uic.cs342.project3.frontend.GameController"
      styleClass="screen-root">

    <Region styleClass="bg-gradient" prefHeight="0"/>

    <!-- ── Header ── -->
    <HBox styleClass="game-header" alignment="CENTER_LEFT" spacing="16">
        <Button text="← Back to Lobby" styleClass="outline-button" onAction="#handleQuit"/>

        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="4">
            <Label fx:id="matchupLabel" text="Player1 vs Player2" styleClass="game-title"/>
            <HBox alignment="CENTER" spacing="8">
                <Label text="Current Turn:" styleClass="turn-key"/>
                <Label fx:id="turnLabel" text="—" styleClass="turn-badge-red"/>
            </HBox>
        </VBox>

        <!-- spacer to balance left button -->
        <Region prefWidth="140"/>
    </HBox>

    <!-- ── Main body: board + sidebar ── -->
    <HBox VBox.vgrow="ALWAYS" spacing="16" styleClass="game-body">

        <!-- BOARD PANEL -->
        <VBox styleClass="card" alignment="CENTER" HBox.hgrow="ALWAYS" spacing="12">

            <!-- Turn status label above board -->
            <Label fx:id="statusLabel" text="Your Turn!" styleClass="status-your-turn"/>

            <!-- 8×8 board built dynamically in controller -->
            <GridPane fx:id="boardGrid"
                      styleClass="board-grid"
                      alignment="CENTER"/>

            <Label fx:id="playerColorLabel"
                   text="You are playing as: Red"
                   styleClass="player-color-label"/>
        </VBox>

        <!-- SIDEBAR: Players + Chat -->
        <VBox spacing="16" prefWidth="300" minWidth="260">

            <!-- Players card -->
            <VBox styleClass="card" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🏆" styleClass="card-icon"/>
                    <Label text="Players" styleClass="card-title"/>
                </HBox>

                <!-- Red player row -->
                <HBox styleClass="player-row-red" alignment="CENTER_LEFT" spacing="8">
                    <Label fx:id="player1Label" text="Player1" styleClass="player-name"
                           HBox.hgrow="ALWAYS"/>
                    <Label text="Red" styleClass="badge-red"/>
                </HBox>

                <!-- Black player row -->
                <HBox styleClass="player-row-black" alignment="CENTER_LEFT" spacing="8">
                    <Label fx:id="player2Label" text="Player2" styleClass="player-name"
                           HBox.hgrow="ALWAYS"/>
                    <Label text="Black" styleClass="badge-gray"/>
                </HBox>
            </VBox>

            <!-- Chat card (hidden for AI games, matches !gameState.vsAI) -->
            <VBox fx:id="chatCard" styleClass="card" VBox.vgrow="ALWAYS" spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="💬" styleClass="card-icon"/>
                    <Label text="Chat" styleClass="card-title"/>
                </HBox>

                <ScrollPane fx:id="chatScroll"
                            styleClass="chat-scroll"
                            fitToWidth="true"
                            VBox.vgrow="ALWAYS"
                            hbarPolicy="NEVER">
                    <VBox fx:id="chatContainer" styleClass="chat-container" spacing="6"/>
                </ScrollPane>

                <HBox spacing="8">
                    <TextField fx:id="chatInput"
                               promptText="Type a message..."
                               styleClass="auth-field"
                               HBox.hgrow="ALWAYS"
                               onAction="#handleSendMessage"/>
                    <Button text="➤" styleClass="send-button" onAction="#handleSendMessage"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>

    <!-- ── Game Over overlay (shown programmatically) ── -->
    <StackPane fx:id="gameOverOverlay" styleClass="gameover-overlay"
               visible="false" managed="false">
        <VBox styleClass="gameover-card" alignment="CENTER" spacing="20">
            <Label text="♛" styleClass="gameover-crown"/>
            <Label text="Game Over!" styleClass="gameover-title"/>
            <Label fx:id="gameOverMessage" styleClass="gameover-message"/>
            <HBox spacing="16" alignment="CENTER">
                <Button text="🏠  Back to Lobby"
                        styleClass="primary-button"
                        onAction="#handleQuit"/>
                <Button text="🔄  Play Again"
                        styleClass="outline-button"
                        onAction="#handlePlayAgain"/>
            </HBox>
        </VBox>
    </StackPane>
</VBox>
