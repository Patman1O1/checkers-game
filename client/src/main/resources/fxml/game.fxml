<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- mirrors Game.tsx: board (2/3) + sidebar (1/3) + game-over overlay -->
<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="edu.uic.cs342.project3.controller.GameController"
           styleClass="game-root">

    <!-- ── Main Layout ───────────────────────────────────────────────────────── -->
    <BorderPane>

        <!-- ── Header ────────────────────────────────────────────────────────── -->
        <top>
            <HBox styleClass="game-header" alignment="CENTER" spacing="24">
                <padding><Insets top="12" right="20" bottom="12" left="20"/></padding>

                <Button text="← Back to Lobby" onAction="#handleBackToLobby" styleClass="back-button"/>

                <Region HBox.hgrow="ALWAYS"/>

                <VBox alignment="CENTER" spacing="2">
                    <HBox alignment="CENTER" spacing="12">
                        <Label fx:id="player1Label" text="Player 1" styleClass="player-name red-player"/>
                        <Label text="vs" styleClass="vs-label"/>
                        <Label fx:id="player2Label" text="Player 2" styleClass="player-name black-player"/>
                    </HBox>
                    <Label fx:id="turnLabel" text="Loading…" styleClass="turn-label"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="playerColorLabel" text="" styleClass="color-badge"/>
            </HBox>
        </top>

        <!-- ── Board + Sidebar ───────────────────────────────────────────────── -->
        <center>
            <HBox spacing="16">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <!-- ── Board ─────────────────────────────────────────────────── -->
                <VBox spacing="8" alignment="CENTER" HBox.hgrow="ALWAYS">
                    <VBox styleClass="board-card" alignment="CENTER" spacing="8">
                        <GridPane fx:id="boardGrid"
                                  styleClass="board-grid"
                                  gridLinesVisible="false"
                                  alignment="CENTER"/>
                        <Label fx:id="statusLabel" text="" styleClass="status-msg" wrapText="true"/>
                    </VBox>
                </VBox>

                <!-- ── Sidebar ───────────────────────────────────────────────── -->
                <VBox spacing="14" prefWidth="280" minWidth="250">

                    <!-- Players card -->
                    <VBox styleClass="card" spacing="10">
                        <Label text="🏆  Players" styleClass="card-title"/>
                        <Separator/>
                        <HBox styleClass="player-row red-row" alignment="CENTER_LEFT" spacing="8">
                            <padding><Insets top="6" right="8" bottom="6" left="8"/></padding>
                            <Label text="🔴" styleClass="piece-icon"/>
                            <Label fx:id="player1SideLabel" text="Player 1" styleClass="player-row-name" HBox.hgrow="ALWAYS"/>
                            <Label text="Red" styleClass="color-tag-red"/>
                        </HBox>
                        <HBox styleClass="player-row black-row" alignment="CENTER_LEFT" spacing="8">
                            <padding><Insets top="6" right="8" bottom="6" left="8"/></padding>
                            <Label text="⚫" styleClass="piece-icon"/>
                            <Label fx:id="player2SideLabel" text="Player 2" styleClass="player-row-name" HBox.hgrow="ALWAYS"/>
                            <Label text="Black" styleClass="color-tag-black"/>
                        </HBox>
                    </VBox>

                    <!-- Chat card (hidden for AI games) -->
                    <VBox fx:id="chatBox" styleClass="card" VBox.vgrow="ALWAYS" spacing="10">
                        <Label text="💬  Chat" styleClass="card-title"/>
                        <Separator/>
                        <ListView fx:id="chatList"
                                  styleClass="chat-list"
                                  VBox.vgrow="ALWAYS"/>
                        <HBox spacing="8">
                            <TextField fx:id="chatField"
                                       promptText="Type a message…"
                                       styleClass="auth-field"
                                       HBox.hgrow="ALWAYS"
                                       onAction="#handleSendMessage"/>
                            <Button fx:id="sendButton"
                                    text="Send"
                                    onAction="#handleSendMessage"
                                    styleClass="secondary-button"/>
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>
        </center>
    </BorderPane>

    <!-- ── Game-Over Overlay ─────────────────────────────────────────────────── -->
    <VBox fx:id="gameOverOverlay"
          styleClass="overlay"
          alignment="CENTER"
          spacing="20"
          visible="false" managed="false">

        <VBox styleClass="game-over-card" alignment="CENTER" spacing="16">
            <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

            <Label text="Game Over!" styleClass="game-over-title"/>
            <Label fx:id="gameOverTitle"  text="" styleClass="game-over-outcome"/>
            <Label fx:id="gameOverMessage" text="" styleClass="game-over-desc" wrapText="true"/>

            <Button fx:id="backToLobbyButton"
                    text="🏠  Back to Lobby"
                    onAction="#handleBackToLobby"
                    styleClass="primary-button"/>
        </VBox>
    </VBox>
</StackPane>
