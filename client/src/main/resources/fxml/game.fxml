<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="edu.uic.cs342.controller.GameController"
           styleClass="game-root">

    <!-- ── Main Layout ──────────────────────────────────────────────────────────────────────────────────────────── -->
    <BorderPane>
        <top>
            <!-- ── Header ───────────────────────────────────────────────────────────────────────────────────────── -->
            <HBox styleClass="game-header" alignment="CENTER" spacing="24.0">
                <padding><Insets top="12.0" right="20.0" bottom="12.0" left="20.0"/></padding>

                <Button text="← Back to Lobby" onAction="#handleBackToLobby" styleClass="back-button"/>

                <Region HBox.hgrow="ALWAYS"/>

                <VBox alignment="CENTER" spacing="2.0">
                    <HBox alignment="CENTER" spacing="12.0">
                        <Label fx:id="player1Label" text="Player 1" styleClass="player-name red-player"/>
                        <Label text="vs" styleClass="vs-label"/>
                        <Label fx:id="player2Label" text="Player 2" styleClass="player-name black-player"/>
                    </HBox>
                    <Label fx:id="turnLabel" text="Loading…" styleClass="turn-label"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="playerColorLabel" styleClass="color-badge"/>
            </HBox>
        </top>

        <center>
            <HBox spacing="16.0">
                <padding><Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/></padding>

                <!-- ── Board ────────────────────────────────────────────────────────────────────────────────────── -->
                <VBox spacing="8.0" alignment="CENTER" HBox.hgrow="ALWAYS">
                    <VBox styleClass="board-card" alignment="CENTER" spacing="8.0">
                        <GridPane fx:id="boardGrid" styleClass="board-grid" alignment="CENTER"/>
                        <Label fx:id="statusLabel" styleClass="status-message" wrapText="true"/>
                    </VBox>
                </VBox>

                <!-- ── Sidebar ──────────────────────────────────────────────────────────────────────────────────── -->
                <VBox spacing="14.0" prefWidth="280.0" minWidth="250.0">

                    <!-- ── Players Card ─────────────────────────────────────────────────────────────────────────── -->
                    <VBox styleClass="card" spacing="10.0">
                        <Label text="Players" styleClass="card-title"/>
                        <Separator/>
                        <HBox styleClass="player-row red-row" alignment="CENTER_LEFT" spacing="8.0">
                            <padding><Insets top="6.0" right="8.0" bottom="6.0" left="8.0"/></padding>
                            <Label text="🔴" styleClass="piece-icon"/>
                            <Label fx:id="player1SideLabel" text="Player 1" styleClass="player-row-name" HBox.hgrow="ALWAYS"/>
                            <Label text="Red" styleClass="color-tag-red"/>
                        </HBox>
                        <HBox styleClass="player-row black-row" alignment="CENTER_LEFT" spacing="8.0">
                            <padding><Insets top="6.0" right="8.0" bottom="6.0" left="8.0"/></padding>
                            <Label text="⚫" styleClass="piece-icon"/>
                            <Label fx:id="player2SideLabel" text="Player 2" styleClass="player-row-name" HBox.hgrow="ALWAYS"/>
                            <Label text="Black" styleClass="color-tag-black"/>
                        </HBox>
                    </VBox>

                    <!-- ── Chat card ────────────────────────────────────────────────────────────────────────────── -->
                    <VBox fx:id="chatBox" styleClass="card" VBox.vgrow="ALWAYS" spacing="10.0">
                        <Label text="💬  Chat" styleClass="card-title"/>
                        <Separator/>
                        <ListView fx:id="chatList" styleClass="chat-list" VBox.vgrow="ALWAYS"/>
                        <HBox spacing="8.0">
                            <TextField fx:id="chatField"
                                       promptText="Type a message…"
                                       styleClass="auth-field"
                                       HBox.hgrow="ALWAYS"
                                       onAction="#handleSendMessage"/>
                            <Button fx:id="sendButton"
                                    text="Send"
                                    onAction="#handleSendMessage"
                                    styleClass="secondary-button"/>
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>
        </center>
    </BorderPane>

    <!-- ── Game-Over Overlay ────────────────────────────────────────────────────────────────────────────────────── -->
    <VBox fx:id="gameOverOverlay"
          styleClass="overlay"
          alignment="CENTER"
          spacing="20.0"
          visible="false" managed="false">

        <VBox styleClass="game-over-card" alignment="CENTER" spacing="16.0">
            <padding><Insets top="40.0" right="60.0" bottom="40.0" left="60.0"/></padding>

            <Label text="Game Over!" styleClass="game-over-title"/>
            <Label fx:id="gameOverTitle" styleClass="game-over-outcome"/>
            <Label fx:id="gameOverMessage" styleClass="game-over-desc" wrapText="true"/>

            <Button fx:id="backToLobbyButton"
                    text="Back to Lobby"
                    onAction="#handleBackToLobby"
                    styleClass="primary-button"/>
        </VBox>
    </VBox>
</StackPane>